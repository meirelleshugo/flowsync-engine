{
  "typescript.validate.enable": false,
  "nodeModulesDir": "auto",
  "deno.unstable": true,
  "deno.enable": true,
  "deno.lint": true,
  "tasks": {
    "dev": "deno run --watch -N -R -E -S --allow-ffi --env-file ./src/main.ts",
    "test": "deno run -N -R -E -S --env-file test.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@zarco/isness": "jsr:@zarco/isness@^0.1.18",
    "bcrypt": "npm:bcrypt@^6.0.0",
    "bcryptjs": "npm:bcryptjs@^3.0.3",
    "express": "npm:express@^5.2.1",
    "jsonwebtoken": "npm:jsonwebtoken@^9.0.3",
    "mongodb": "npm:mongodb@^7.2.0",
    "mongoose": "npm:mongoose@8.9.5",
    "mongoose-aggregate-paginate-v2": "npm:mongoose-aggregate-paginate-v2@^1.1.4",
    "morgan": "npm:morgan@^1.10.1",
    "octokit": "npm:octokit@^5.0.5",
    "request-check": "npm:request-check@^1.6.2",
    "responser": "npm:responser@^2.5.6",
    "swagger-jsdoc": "npm:swagger-jsdoc@^6.2.8",
    "swagger-ui-dist": "npm:swagger-ui-dist@^5.32.5",
    "swagger-ui-express": "npm:swagger-ui-express@^5.0.1",
    "throwlhos": "npm:throwlhos@^1.1.0"
  },
  "allowScripts": {
    "allow": ["npm:@scarf/scarf", "npm:bcrypt@6.0.0"],
    "deny": ["npm:@scarf/scarf@1.4.0"]
  }
}
